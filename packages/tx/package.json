{
  "name": "@luxwallet/tx",
  "version": "0.2.0",
  "description": "Per-VM transaction builders. EVM/Solana/XRP/TON/Bitcoin are real; Polkadot/Cardano are partial (caller-supplied chain state); Lux P/X/UTXO/ZK are typed stubs.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "browser": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build",
    "test": "vitest run"
  },
  "dependencies": {
    "@emurgo/cardano-serialization-lib-nodejs": "^15.0.3",
    "@luxwallet/chains": "workspace:*",
    "@polkadot/types": "^16.5.6",
    "@polkadot/util": "^14.0.3",
    "@scure/base": "^2.2.0",
    "@scure/btc-signer": "^2.2.0",
    "@solana/web3.js": "^1.98.4",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "viem": "^2.21.0",
    "xrpl": "^5.0.0"
  },
  "devDependencies": {
    "@polkadot/types-support": "^16.5.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
