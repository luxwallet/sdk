{
  "name": "@luxwallet/chains",
  "version": "0.0.0",
  "description": "Lux Wallet chain registry — one source of truth. Emits chains.json for native (Kotlin/Swift) consumers.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "chains.json"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "browser": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./chains.json": "./chains.json"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "emit": "tsx scripts/emit-chains.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
